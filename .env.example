# Required Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Required Groq API Cloud Inference Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# Required Target Broadcast Chat ID / Channel ID for 07:00 IST Morning Briefs
BROADCAST_CHAT_ID=-1001234567890

# Optional Database Storage Filepath
DATABASE_PATH=data/preparation.db

# Optional Active Scheduler Timezone & Trigger Schedule
TIMEZONE=Asia/Kolkata
SEND_TIME=07:00

# Optional Logging Verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO